# Copy to .env on the SERVER (never commit the real .env — it is git-ignored).
# The chatbot proxy reads these at runtime.

# Anthropic API key (server-side only; never exposed to the browser).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for the chatbot. Default is the most capable Opus tier.
# Use claude-haiku-4-5 for the cheapest/fastest option on a public site.
CHAT_MODEL=claude-opus-4-8

# Max tokens per reply (keeps answers short and costs bounded).
CHAT_MAX_TOKENS=1024
